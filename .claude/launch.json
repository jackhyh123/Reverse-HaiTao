{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "DeepTutor Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/web",
      "port": 3782,
      "autoPort": true
    },
    {
      "name": "DeepTutor Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "deeptutor.api.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "port": 8001,
      "autoPort": true
    }
  ]
}
